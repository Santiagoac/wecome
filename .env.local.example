# Handoffs - URLs externas (clientes / originación)
# Crédito Pyme: precalificación en Moffin Fast Track
NEXT_PUBLIC_MOFFIN_PYME_URL=https://app.moffin.mx/wecome/precalificacion

# Dynamicore: panel del cliente Pyme y login del empleado nómina
NEXT_PUBLIC_DYNAMICORE_PANEL_URL=https://wecome.dynamicore.io/login
NEXT_PUBLIC_DYNAMICORE_NOMINA_URL=https://wecome.dynamicore.io/nomina/login

# WhatsApp del agente Wecome (sin '+' ni espacios, formato E.164)
